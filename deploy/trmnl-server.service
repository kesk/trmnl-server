[Unit]
Description=TRMNL forecast server
After=network-online.target
Wants=network-online.target

[Service]
Type=simple
User=seb
WorkingDirectory=/home/seb/trmnl-server
Environment=FORECAST_HOURS=23
Environment=FORECAST_LAT=57.715722
Environment=FORECAST_LON=12.035778
ExecStart=/usr/bin/java -jar /home/seb/trmnl-server/trmnl-server.jar --serve
Restart=on-failure
RestartSec=5

[Install]
WantedBy=multi-user.target
