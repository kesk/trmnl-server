<?xml version="1.0" encoding="UTF-8"?>
<!--
  Logging config for trmnl-server's own diagnostics. tools.logging routes through SLF4J to
  logback. Device telemetry (POST /api/log) is NOT handled here — the server writes those
  raw JSON lines to logs/device-<date>.log itself (see server/append-device-log!), so this
  config only covers the main server log.

  STDOUT keeps output flowing to the terminal (and, under systemd, to journald) exactly
  as the old println calls did. FILE is a rolling file appender: it writes to an active
  file and, once a day, rolls it to a gzipped, date-stamped archive, keeping ~a month of
  history and deleting older archives — so the file can't grow unbounded and fill the Pi's
  SD card, with no external logrotate needed. Override the active path with the LOG_FILE
  env var (the systemd unit sets WorkingDirectory, so the default is relative to that).
-->
<configuration>
  <appender name="STDOUT" class="ch.qos.logback.core.ConsoleAppender">
    <encoder>
      <pattern>%d{yyyy-MM-dd HH:mm:ss.SSS} %-5level [%thread] %logger{0} - %msg%n</pattern>
    </encoder>
  </appender>

  <appender name="FILE" class="ch.qos.logback.core.rolling.RollingFileAppender">
    <file>${LOG_FILE:-logs/trmnl-server.log}</file>
    <rollingPolicy class="ch.qos.logback.core.rolling.TimeBasedRollingPolicy">
      <!-- Roll daily to e.g. trmnl-server.log.2026-07-11.gz; keep 30 archives (~a
           month), then delete the oldest. totalSizeCap is a belt-and-suspenders limit
           so a runaway day can't fill the disk before maxHistory catches up. -->
      <fileNamePattern>${LOG_FILE:-logs/trmnl-server.log}.%d{yyyy-MM-dd}.gz</fileNamePattern>
      <maxHistory>30</maxHistory>
      <totalSizeCap>100MB</totalSizeCap>
    </rollingPolicy>
    <encoder>
      <pattern>%d{yyyy-MM-dd HH:mm:ss.SSS} %-5level [%thread] %logger{0} - %msg%n</pattern>
    </encoder>
  </appender>

  <root level="INFO">
    <appender-ref ref="STDOUT" />
    <appender-ref ref="FILE" />
  </root>
</configuration>
